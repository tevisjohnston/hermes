+const { chromium, devices } = require('playwright');
+const fs = require('fs');
+const path = require('path');
+
+const urls = {
+  home: 'https://7figure.affiliatemarketconnect.com/',
+  about: 'https://7figure.affiliatemarketconnect.com/about-michael/',
+  contact: 'https://7figure.affiliatemarketconnect.com/contact/',
+  products: 'https://7figure.affiliatemarketconnect.com/products/',
+  unsubscribe: 'https://7figure.affiliatemarketconnect.com/unsubscribe/',
+  thank_you: 'https://7figure.affiliatemarketconnect.com/thank-you/',
+  terms: 'https://7figure.affiliatemarketconnect.com/terms-conditions/',
+  privacy: 'https://7figure.affiliatemarketconnect.com/privacy-policy/',
+  disclosure: 'https://7figure.affiliatemarketconnect.com/affiliate-disclosure/',
+  blog_warrior: 'https://7figure.affiliatemarketconnect.com/warriorplus-review-2026/',
+  blog_jvzoo: 'https://7figure.affiliatemarketconnect.com/jvzoo-create-list-sell-scale/',
+  product_ai: 'https://7figure.affiliatemarketconnect.com/affiliate-product/ai-franchise/'
+};
+
+async function capture() {
+  const screenshotDir = path.join(__dirname, 'screenshots');
+  if (!fs.existsSync(screenshotDir)) {
+    fs.mkdirSync(screenshotDir);
+  }
+
+  console.log('Launching browser...');
+  const browser = await chromium.launch({
+    args: ['--no-sandbox', '--disable-setuid-sandbox']
+  });
+
+  // Desktop context
+  const desktopContext = await browser.newContext({
+    viewport: { width: 1280, height: 800 },
+    ignoreHTTPSErrors: true
+  });
+
+  // Mobile context (iPhone 12)
+  const mobileContext = await browser.newContext({
+    ...devices['iPhone 12'],
+    ignoreHTTPSErrors: true
+  });
+
+  for (const [name, url] of Object.entries(urls)) {
+    console.log(`Capturing ${name}...`);
+    try {
+      // Desktop
+      const dPage = await desktopContext.newPage();
+      await dPage.goto(url, { waitUntil: 'networkidle', timeout: 20000 });
+      // Add extra wait to ensure images and styles render
+      await dPage.waitForTimeout(2000);
+      await dPage.screenshot({ path: path.join(screenshotDir, `${name}_desktop.png`), fullPage: true });
+      await dPage.close();
+      console.log(`  - Desktop done`);
+
+      // Mobile
+      const mPage = await mobileContext.newPage();
+      await mPage.goto(url, { waitUntil: 'networkidle', timeout: 20000 });
+      // Add extra wait to ensure images and styles render
+      await mPage.waitForTimeout(2000);
+      await mPage.screenshot({ path: path.join(screenshotDir, `${name}_mobile.png`), fullPage: true });
+      await mPage.close();
+      console.log(`  - Mobile done`);
+    } catch (e) {
+      console.error(`Error capturing ${name}:`, e.message);
+    }
+  }
+
+  await browser.close();
+  console.log('Done capturing all screenshots!');
+}
+
+capture();
