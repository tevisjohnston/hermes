+import subprocess
+import json
+import sys
+import re
+
+DATABASES = {
+    "affiliatemarketconnect": {
+        "container": "affiliatemarketconnectcom-db-1",
+        "db_name": "wp_db_affiliate_market_connect"
+    },
+    "7figure": {
+        "container": "7figureaffiliatemarketconnectcom-db_2-1",
+        "db_name": "wp_db_7figure"
+    }
+}
+
+def run_query(container, db_name, sql):
+    # Get password from container env
+    try:
+        pw_proc = subprocess.run(
+            ["docker", "exec", container, "printenv", "MYSQL_ROOT_PASSWORD"],
+            capture_output=True, text=True, check=True
+        )
+        password = pw_proc.stdout.strip()
+    except Exception as e:
+        print(f"Error getting root password for container {container}: {e}")
+        return None
+
+    # Run query
+    cmd = [
+        "docker", "exec", "-i", container,
+        "mysql", "-uroot", f"-p{password}", db_name, "-s", "-N", "-e", sql
+    ]
+    try:
+        proc = subprocess.run(cmd, capture_output=True, text=True, check=True)
+        return proc.stdout.strip()
+    except subprocess.CalledProcessError as e:
+        print(f"Error executing query on {db_name}: {e.stderr}")
+        return None
+
+def audit_db(name, config):
+    container = config["container"]
+    db_name = config["db_name"]
+    print(f"\n==================================================")
+    print(f" AUDIT REPORT FOR: {name.upper()} ({db_name})")
+    print(f"==================================================")
+
+    # 1. Row counts of all tables
+    print("\n--- Table Summary & Row Counts ---")
+    sql_tables = "SELECT table_name, table_rows, data_length, index_length FROM information_schema.tables WHERE table_schema = DATABASE();"
+    res = run_query(container, db_name, sql_tables)
+    tables = []
+    if res:
+        for line in res.splitlines():
+            parts = line.split("\t")
+            if len(parts) >= 4:
+                t_name, t_rows, data_len, idx_len = parts
+                t_rows = int(t_rows) if t_rows.isdigit() else 0
+                data_mb = int(data_len) / (1024 * 1024) if data_len.isdigit() else 0.0
+                idx_mb = int(idx_len) / (1024 * 1024) if idx_len.isdigit() else 0.0
+                tables.append((t_name, t_rows, data_mb, idx_mb))
+                print(f"  {t_name:<35} | Rows: {t_rows:>6} | Data: {data_mb:>6.2f} MB | Index: {idx_mb:>6.2f} MB")
+    
+    # 2. Orphaned records
+    print("\n--- Orphaned Records Audit ---")
+    
+    # Postmeta without posts
+    orph_pm = run_query(container, db_name, "SELECT COUNT(*) FROM wp_postmeta pm LEFT JOIN wp_posts p ON pm.post_id = p.ID WHERE p.ID IS NULL;")
+    # Commentmeta without comments
+    orph_cm = run_query(container, db_name, "SELECT COUNT(*) FROM wp_commentmeta cm LEFT JOIN wp_comments c ON cm.comment_id = c.comment_ID WHERE c.comment_ID IS NULL;")
+    # Term relationships without posts (orphaned objects)
+    # Let's make sure we check terms whose posts do not exist anymore
+    orph_tr = run_query(container, db_name, "SELECT COUNT(*) FROM wp_term_relationships tr LEFT JOIN wp_posts p ON tr.object_id = p.ID WHERE p.ID IS NULL;")
+    # Usermeta without users
+    orph_um = run_query(container, db_name, "SELECT COUNT(*) FROM wp_usermeta um LEFT JOIN wp_users u ON um.user_id = u.ID WHERE u.ID IS NULL;")
+    # Terms without taxonomy
+    orph_t = run_query(container, db_name, "SELECT COUNT(*) FROM wp_terms t LEFT JOIN wp_term_taxonomy tt ON t.term_id = tt.term_id WHERE tt.term_id IS NULL;")
+    
