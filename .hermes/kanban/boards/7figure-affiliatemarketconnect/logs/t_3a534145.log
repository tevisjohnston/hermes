+import os
+import re
+import difflib
+
+theme_dir = "/home/tevis/7figure.affiliatemarketconnect.com/wp-content/themes/7_Figure_Affiliate"
+
+def replace_font_display_in_p(fpath):
+    with open(fpath, "r", encoding="utf-8") as f:
+        content = f.read()
+
+    # Regex to find <p ... class="... font-display ...">
+    # We want to find font-display within the class attribute of a <p> tag.
+    # To handle cases where there might be other attributes, we can use a callback or a robust regex.
+    p_tag_pattern = re.compile(r'(<p\b[^>]*\bclass=["\'])([^"\']*)(\bfont-display\b)([^"\']*)(["\'][^>]*>)', re.IGNORECASE)
+
+    new_content, count = p_tag_pattern.subn(r'\1\2font-body\4\5', content)
+
+    if count > 0:
+        print(f"File: {fpath}")
+        print(f"Replaced {count} occurrences.")
+        diff = difflib.unified_diff(
+            content.splitlines(),
+            new_content.splitlines(),
+            fromfile=f"a/{os.path.basename(fpath)}",
+            tofile=f"b/{os.path.basename(fpath)}",
+            lineterm=""
+        )
+        for line in diff:
+            print(line)
+        print("-" * 40)
+        
+        # Write back changes
+        with open(fpath, "w", encoding="utf-8") as f:
+            f.write(new_content)
+
+def main():
+    for root, dirs, files in os.walk(theme_dir):
+        if "vendor" in root or "node_modules" in root:
+            continue
+        for f in files:
+            if f.endswith(".php"):
+                fpath = os.path.join(root, f)
+                replace_font_display_in_p(fpath)
+
+if __name__ == "__main__":
+    main()
