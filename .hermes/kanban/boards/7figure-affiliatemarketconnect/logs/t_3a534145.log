+import os
+
+def update_file(fpath):
+    print(f"\nUpdating {os.path.basename(fpath)}...")
+    with open(fpath, 'r', encoding='utf-8') as f:
+        content = f.read()
+        
+    orig_content = content
+    
+    # 1. Update Hero H1
+    content = content.replace(
+        '<h1 class="text-4xl lg:text-6xl font-bold leading-tight text-white">',
+        '<h1 class="font-body text-4xl md:text-6xl font-bold text-white">'
+    )
+    
+    # 2. Update Hero Subtitle / Last updated paragraph
+    content = content.replace(
+        '<p class="text-slate-100 font-semibold">',
+        '<p class="font-display text-base text-slate-100 font-semibold">'
+    )
+    
+    # 3. Update standard H2 tags
+    content = content.replace(
+        '<h2 class="text-2xl font-bold text-white">',
+        '<h2 class="font-display text-2xl md:text-3xl font-bold text-white">'
+    )
+    
+    # 4. Update standard p tags with text-slate-300
+    content = content.replace(
+        '<p class="text-slate-300">',
+        '<p class="font-display text-base text-slate-300">'
+    )
+    
+    # 5. Update contact details standard p tags
+    # Let's find:
+    #             <div class="rounded-xl bg-white/5 p-5 ring-1 ring-white/10 text-slate-300 space-y-1">
+    #                 <p>AFFILIATE MARKET CONNECT LLC</p>
+    #                 ...
+    #             </div>
+    old_contact_block = """            <div class="rounded-xl bg-white/5 p-5 ring-1 ring-white/10 text-slate-300 space-y-1">
+                <p>AFFILIATE MARKET CONNECT LLC</p>
+                <p>21420 Plane Tree Ln Unit 204</p>
+                <p>Newhall, CA 91321</p>
+                <p>United States</p>
+                <p>Email: tevis.johnston@affiliatemarketconnect.com</p>
+            </div>"""
+            
+    new_contact_block = """            <div class="rounded-xl bg-white/5 p-5 ring-1 ring-white/10 text-slate-300 space-y-1">
+                <p class="font-display text-base">AFFILIATE MARKET CONNECT LLC</p>
+                <p class="font-display text-base">21420 Plane Tree Ln Unit 204</p>
+                <p class="font-display text-base">Newhall, CA 91321</p>
+                <p class="font-display text-base">United States</p>
+                <p class="font-display text-base">Email: tevis.johnston@affiliatemarketconnect.com</p>
+            </div>"""
+            
+    content = content.replace(old_contact_block, new_contact_block)
+    
+    if content == orig_content:
+        print("No changes made.")
+    else:
+        with open(fpath, 'w', encoding='utf-8') as f:
+            f.write(content)
+        print("Successfully updated!")
+
+if __name__ == '__main__':
+    update_file('/home/tevis/7figure.affiliatemarketconnect.com/wp-content/themes/7_Figure_Affiliate/page-terms-conditions.php')
+    update_file('/home/tevis/7figure.affiliatemarketconnect.com/wp-content/themes/7_Figure_Affiliate/page-affiliate-disclosure.php')
+    update_file('/home/tevis/7figure.affiliatemarketconnect.com/wp-content/themes/7_Figure_Affiliate/page-privacy-policy.php')
